<launch>
  <include file="$(find turtlebot_bringup)/launch/minimal.launch" />
  <include file="$(find usb_cam)/launch/usb_cam-test.launch" />
  <include file="$(find astra_launch)/launch/astra.launch" />

  <node pkg="p2_lizijun" type="p2b_ball_follower.py" name="p2b_ball_follower" output="screen">
    <rosparam command="load" file="$(find p2_lizijun)/config/p2b_params.yaml" />
  </node>
</launch>
